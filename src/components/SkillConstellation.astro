---
import profile from '../data/profile.json';

const skills = profile.skills;
const categories = [...new Set(skills.map(s => s.category))];
---

<section class="mt-16">
  <div class="flex items-center justify-between mb-6">
    <h2 class="text-2xl font-semibold" transition:name="skills-heading">Skills & Technologies</h2>
    <button
      id="constellation-toggle"
      class="text-xs text-muted hover:text-accent border border-border rounded-full px-3 py-1 transition-colors"
      aria-pressed="false"
    >
      View as list
    </button>
  </div>

  <div id="constellation-canvas-wrap" class="relative rounded-xl border border-border bg-surface/50 overflow-hidden" style="height: 380px;">
    <canvas id="skill-constellation" aria-hidden="true" role="presentation"></canvas>
  </div>

  <div id="constellation-list" class="hidden">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {categories.map(cat => (
        <div>
          <h3 class="text-sm font-semibold text-accent uppercase tracking-wider mb-3">{cat}</h3>
          <ul class="flex flex-col gap-2">
            {skills.filter(s => s.category === cat).map(skill => (
              <li class="flex items-center justify-between text-sm">
                <span class="text-text">{skill.name}</span>
                <div class="flex gap-1" aria-label={`Proficiency: ${skill.level} out of 5`}>
                  {[1,2,3,4,5].map(i => (
                    <span class={`w-2 h-2 rounded-full ${i <= skill.level ? 'bg-accent' : 'bg-border'}`} />
                  ))}
                </div>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  {/* Screen-reader accessible list (always in DOM) */}
  <div class="sr-only" role="list" aria-label="Skills and technologies">
    {categories.map(cat => (
      <div role="listitem">
        <strong>{cat}:</strong>
        {skills.filter(s => s.category === cat).map(s => `${s.name} (${s.level}/5)`).join(', ')}
      </div>
    ))}
  </div>
</section>

<script define:vars={{ skills, categories }}>
  // Pass data to client script via window
  window.__skillsData = { skills, categories };
</script>

<script>
  function initConstellation() {
    const canvas = document.getElementById('skill-constellation') as HTMLCanvasElement;
    const wrap = document.getElementById('constellation-canvas-wrap');
    const listEl = document.getElementById('constellation-list');
    const toggleBtn = document.getElementById('constellation-toggle');
    if (!canvas || !wrap) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    const data = (window as any).__skillsData;
    if (!data) return;

    const { skills, categories } = data as {
      skills: { name: string; category: string; level: number }[];
      categories: string[];
    };

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Toggle button
    let showList = false;
    toggleBtn?.addEventListener('click', () => {
      showList = !showList;
      wrap!.classList.toggle('hidden', showList);
      listEl?.classList.toggle('hidden', !showList);
      toggleBtn.textContent = showList ? 'View as constellation' : 'View as list';
      toggleBtn.setAttribute('aria-pressed', String(showList));
    });

    // Canvas sizing
    let w: number, h: number;
    function resize() {
      const rect = wrap!.getBoundingClientRect();
      w = canvas.width = rect.width * Math.min(window.devicePixelRatio, 2);
      h = canvas.height = rect.height * Math.min(window.devicePixelRatio, 2);
      canvas.style.width = rect.width + 'px';
      canvas.style.height = rect.height + 'px';
      ctx!.scale(Math.min(window.devicePixelRatio, 2), Math.min(window.devicePixelRatio, 2));
    }
    resize();

    const dpr = Math.min(window.devicePixelRatio, 2);
    const cw = w / dpr;
    const ch = h / dpr;

    // Category colors
    const catColors: Record<string, string> = {
      Frontend: '#6188e0',
      Backend: '#e0a861',
      Languages: '#61e088',
      DevOps: '#e06188',
      Tools: '#a861e0',
      Leadership: '#e0d461',
    };

    // Node setup
    interface Node {
      x: number; y: number; vx: number; vy: number;
      name: string; category: string; level: number;
      radius: number; targetX: number; targetY: number;
    }

    // Distribute nodes in category clusters
    const catCenters: Record<string, { x: number; y: number }> = {};
    const padding = 60;
    categories.forEach((cat: string, i: number) => {
      const angle = (i / categories.length) * Math.PI * 2 - Math.PI / 2;
      const rx = (cw - padding * 2) * 0.3;
      const ry = (ch - padding * 2) * 0.3;
      catCenters[cat] = {
        x: cw / 2 + Math.cos(angle) * rx,
        y: ch / 2 + Math.sin(angle) * ry,
      };
    });

    const nodes: Node[] = skills.map((s: any, i: number) => {
      const center = catCenters[s.category];
      const jitter = 40;
      return {
        x: center.x + (Math.random() - 0.5) * jitter,
        y: center.y + (Math.random() - 0.5) * jitter,
        vx: 0, vy: 0,
        name: s.name,
        category: s.category,
        level: s.level,
        radius: 6 + s.level * 3,
        targetX: center.x + (Math.random() - 0.5) * jitter,
        targetY: center.y + (Math.random() - 0.5) * jitter,
      };
    });

    // Mouse interaction
    let mouseX = -1000, mouseY = -1000;
    let dragNode: Node | null = null;

    canvas.style.pointerEvents = 'auto';
    wrap!.addEventListener('mousemove', (e) => {
      const rect = wrap!.getBoundingClientRect();
      mouseX = e.clientX - rect.left;
      mouseY = e.clientY - rect.top;
      if (dragNode) {
        dragNode.x = mouseX;
        dragNode.y = mouseY;
        dragNode.vx = 0;
        dragNode.vy = 0;
      }
    });
    wrap!.addEventListener('mousedown', (e) => {
      const rect = wrap!.getBoundingClientRect();
      const mx = e.clientX - rect.left;
      const my = e.clientY - rect.top;
      for (const n of nodes) {
        const dx = n.x - mx, dy = n.y - my;
        if (Math.sqrt(dx * dx + dy * dy) < n.radius + 4) {
          dragNode = n;
          canvas.style.cursor = 'grabbing';
          break;
        }
      }
    });
    wrap!.addEventListener('mouseup', () => {
      dragNode = null;
      canvas.style.cursor = 'default';
    });
    wrap!.addEventListener('mouseleave', () => {
      mouseX = -1000;
      mouseY = -1000;
      dragNode = null;
      canvas.style.cursor = 'default';
    });

    // Tooltip
    let hoveredNode: Node | null = null;

    function drawFrame() {
      ctx!.clearRect(0, 0, cw, ch);

      if (!prefersReducedMotion) {
        // Simple force simulation
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const dx = nodes[j].x - nodes[i].x;
            const dy = nodes[j].y - nodes[i].y;
            const dist = Math.sqrt(dx * dx + dy * dy) || 1;
            const minDist = nodes[i].radius + nodes[j].radius + 12;
            if (dist < minDist) {
              const force = (minDist - dist) / dist * 0.05;
              nodes[i].vx -= dx * force;
              nodes[i].vy -= dy * force;
              nodes[j].vx += dx * force;
              nodes[j].vy += dy * force;
            }
          }
          // Pull toward target
          if (nodes[i] !== dragNode) {
            nodes[i].vx += (nodes[i].targetX - nodes[i].x) * 0.005;
            nodes[i].vy += (nodes[i].targetY - nodes[i].y) * 0.005;
            nodes[i].vx *= 0.9;
            nodes[i].vy *= 0.9;
            nodes[i].x += nodes[i].vx;
            nodes[i].y += nodes[i].vy;
          }
        }
      }

      // Draw connections between same-category nodes
      for (let i = 0; i < nodes.length; i++) {
        for (let j = i + 1; j < nodes.length; j++) {
          if (nodes[i].category === nodes[j].category) {
            const dx = nodes[j].x - nodes[i].x;
            const dy = nodes[j].y - nodes[i].y;
            const dist = Math.sqrt(dx * dx + dy * dy);
            if (dist < 120) {
              ctx!.beginPath();
              ctx!.moveTo(nodes[i].x, nodes[i].y);
              ctx!.lineTo(nodes[j].x, nodes[j].y);
              ctx!.strokeStyle = catColors[nodes[i].category] + '25';
              ctx!.lineWidth = 1;
              ctx!.stroke();
            }
          }
        }
      }

      // Draw nodes
      hoveredNode = null;
      for (const n of nodes) {
        const dx = n.x - mouseX, dy = n.y - mouseY;
        const isHovered = Math.sqrt(dx * dx + dy * dy) < n.radius + 4;
        if (isHovered) hoveredNode = n;

        const color = catColors[n.category] || '#6188e0';

        // Glow on hover
        if (isHovered) {
          ctx!.beginPath();
          ctx!.arc(n.x, n.y, n.radius + 6, 0, Math.PI * 2);
          ctx!.fillStyle = color + '20';
          ctx!.fill();
        }

        ctx!.beginPath();
        ctx!.arc(n.x, n.y, n.radius, 0, Math.PI * 2);
        ctx!.fillStyle = color + (isHovered ? 'cc' : '60');
        ctx!.fill();
        ctx!.strokeStyle = color + '80';
        ctx!.lineWidth = 1;
        ctx!.stroke();

        // Label
        ctx!.font = `${isHovered ? '12' : '10'}px Inter, system-ui, sans-serif`;
        ctx!.fillStyle = isHovered ? '#e4e4e7' : '#a1a1aa';
        ctx!.textAlign = 'center';
        ctx!.fillText(n.name, n.x, n.y + n.radius + 14);
      }

      // Tooltip for hovered node
      if (hoveredNode) {
        const n = hoveredNode;
        const tooltipText = `${n.name} · ${n.category} · ${'★'.repeat(n.level)}${'☆'.repeat(5 - n.level)}`;
        ctx!.font = '12px Inter, system-ui, sans-serif';
        const tw = ctx!.measureText(tooltipText).width + 16;
        const tx = Math.min(Math.max(n.x - tw / 2, 4), cw - tw - 4);
        const ty = n.y - n.radius - 28;
        ctx!.fillStyle = '#1a1a1a';
        ctx!.strokeStyle = '#333';
        ctx!.lineWidth = 1;
        ctx!.beginPath();
        ctx!.roundRect(tx, ty, tw, 22, 6);
        ctx!.fill();
        ctx!.stroke();
        ctx!.fillStyle = '#e4e4e7';
        ctx!.textAlign = 'left';
        ctx!.fillText(tooltipText, tx + 8, ty + 15);
      }

      canvas.style.cursor = hoveredNode ? 'grab' : 'default';
    }

    if (prefersReducedMotion) {
      drawFrame();
    } else {
      let animId: number;
      function loop() {
        drawFrame();
        animId = requestAnimationFrame(loop);
      }
      loop();

      document.addEventListener('visibilitychange', () => {
        if (document.hidden) cancelAnimationFrame(animId);
        else animId = requestAnimationFrame(loop);
      });

      document.addEventListener('astro:before-swap', () => {
        cancelAnimationFrame(animId);
      }, { once: true });
    }

    window.addEventListener('resize', () => {
      resize();
    });
  }

  document.addEventListener('astro:page-load', initConstellation);
</script>
