---
import profile from '../data/profile.json';
const { experience, skills } = profile;
---

<!-- Terminal trigger button -->
<button
  id="terminal-trigger"
  class="terminal-trigger-btn"
  aria-label="Open terminal"
  title="Open terminal (Ctrl+`)"
>
  <span aria-hidden="true">&gt;_</span>
</button>

<!-- Terminal overlay -->
<div
  id="terminal-overlay"
  class="terminal-overlay hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Interactive terminal"
>
  <div class="terminal-window" id="terminal-window">
    <div class="terminal-header" id="terminal-header">
      <div class="terminal-dots" id="terminal-dots">
        <button class="dot dot-red"    id="terminal-btn-close"    title="Close"    aria-label="Close terminal"></button>
        <button class="dot dot-yellow" id="terminal-btn-minimize" title="Minimize" aria-label="Minimize terminal"></button>
        <button class="dot dot-green"  id="terminal-btn-maximize" title="Maximize" aria-label="Maximize terminal"></button>
      </div>
      <span class="terminal-title" id="terminal-title">daniel@portfolio ~ %</span>
    </div>
    <div class="terminal-body" id="terminal-body">
      <div id="terminal-output" aria-live="polite" role="log"></div>
      <div class="terminal-input-line" id="terminal-input-line">
        <span class="terminal-prompt" id="terminal-prompt" aria-hidden="true">daniel@portfolio ~ %</span>
        <span class="terminal-display-area" id="terminal-display-area" aria-hidden="true"><span id="term-before-cursor"></span><span class="term-cursor" id="term-cursor">&nbsp;</span><span id="term-after-cursor"></span></span>
        <input
          type="text"
          id="terminal-input"
          class="terminal-input-hidden"
          aria-label="Terminal command input"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
        />
      </div>
    </div>
    <div class="terminal-resize-handle" id="terminal-resize-handle" aria-hidden="true"></div>
  </div>
</div>

<style>
  .terminal-trigger-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    z-index: 40;
    width: 44px;
    height: 44px;
    border-radius: 12px;
    background: #141414;
    border: 1px solid #27272a;
    color: #71717a;
    font-family: Menlo, Monaco, 'SF Mono', 'Courier New', monospace;
    font-size: 14px;
    font-weight: bold;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .terminal-trigger-btn:hover,
  .terminal-trigger-btn:focus-visible {
    border-color: #22c55e;
    color: #22c55e;
    box-shadow: 0 0 12px rgba(34, 197, 94, 0.15);
    outline: none;
  }

  .terminal-overlay {
    position: fixed;
    inset: 0;
    z-index: 50;
    background: rgba(0, 0, 0, 0.65);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 24px;
  }
  .terminal-overlay.hidden { display: none; }

  .terminal-window {
    position: relative;
    width: 680px;
    height: 460px;
    min-width: 380px;
    min-height: 200px;
    background: rgba(13, 13, 13, 0.97);
    border: 1px solid #2a2a2a;
    border-radius: 11px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    box-shadow: 0 28px 72px rgba(0, 0, 0, 0.65), 0 0 0 0.5px rgba(255,255,255,0.06);
  }
  .terminal-window.terminal-minimized .terminal-body { display: none; }
  .terminal-window.terminal-minimized { height: auto; min-height: 0; }
  .terminal-window.terminal-maximized {
    position: fixed !important;
    left: 0 !important;
    top: 0 !important;
    width: 100vw !important;
    height: 100vh !important;
    border-radius: 0;
    border: none;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: #1c1c1e;
    border-bottom: 1px solid #2a2a2a;
    user-select: none;
    cursor: grab;
    flex-shrink: 0;
  }
  .terminal-header.is-dragging { cursor: grabbing; }

  .terminal-dots { display: flex; gap: 8px; flex-shrink: 0; }
  .dot {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: none;
    cursor: pointer;
    padding: 0;
    flex-shrink: 0;
    transition: filter 0.1s;
  }
  .dot:focus-visible { outline: 2px solid #e4e4e7; outline-offset: 2px; }
  .terminal-window:not(:focus-within) .dot-red    { background: #4a4a4a; }
  .terminal-window:not(:focus-within) .dot-yellow { background: #4a4a4a; }
  .terminal-window:not(:focus-within) .dot-green  { background: #4a4a4a; }
  .terminal-window:focus-within .dot-red    { background: #ff5f57; }
  .terminal-window:focus-within .dot-yellow { background: #febc2e; }
  .terminal-window:focus-within .dot-green  { background: #28c840; }
  .dot::after {
    content: '';
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 8px;
    font-weight: 700;
    line-height: 12px;
    color: rgba(0,0,0,0.65);
    opacity: 0;
    transition: opacity 0.1s;
  }
  .terminal-dots:hover .dot::after { opacity: 1; }
  .dot-red::after    { content: '\2715'; }
  .dot-yellow::after { content: '\2212'; }
  .dot-green::after  { content: '\002B'; }

  .terminal-title {
    flex: 1;
    text-align: center;
    font-size: 12px;
    color: #8a8a8e;
    font-family: Menlo, Monaco, 'SF Mono', 'Courier New', monospace;
    pointer-events: none;
  }

  .terminal-body {
    flex: 1;
    overflow-y: auto;
    overflow-x: hidden;
    padding: 12px 16px;
    font-family: Menlo, Monaco, 'SF Mono', 'Courier New', monospace;
    font-size: 13px;
    line-height: 1.55;
    color: #e4e4e7;
    scrollbar-width: thin;
    scrollbar-color: #3a3a3a transparent;
    min-height: 0;
  }
  .terminal-body::-webkit-scrollbar { width: 6px; }
  .terminal-body::-webkit-scrollbar-thumb { background: #3a3a3a; border-radius: 3px; }
  .terminal-body::-webkit-scrollbar-track { background: transparent; }
  .terminal-body ::selection { background: rgba(34, 197, 94, 0.25); }

  .terminal-input-line {
    display: flex;
    align-items: baseline;
    gap: 8px;
    margin-top: 2px;
    min-height: 1.55em;
    position: relative;
  }
  .terminal-prompt {
    color: #22c55e;
    font-weight: 600;
    flex-shrink: 0;
    white-space: nowrap;
  }
  .terminal-input-hidden {
    position: absolute;
    left: 0; top: 0;
    width: 1px; height: 1px;
    opacity: 0;
    pointer-events: none;
    background: transparent;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: inherit;
  }
  .terminal-display-area {
    flex: 1;
    white-space: pre-wrap;
    word-break: break-all;
    color: #e4e4e7;
  }
  .term-cursor {
    display: inline-block;
    background: #22c55e;
    color: #0d0d0d;
    min-width: 0.6em;
    animation: blink-cursor 1s step-end infinite;
  }
  @keyframes blink-cursor {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }

  :global(.term-line)    { white-space: pre-wrap; word-break: break-word; }
  :global(.term-cmd)     { color: #22c55e; }
  :global(.term-accent)  { color: #6188e0; }
  :global(.term-success) { color: #22c55e; }
  :global(.term-warn)    { color: #febc2e; }
  :global(.term-muted)   { color: #71717a; }
  :global(.term-error)   { color: #ef4444; }
  :global(.term-bold)    { font-weight: 700; }

  .terminal-resize-handle {
    position: absolute;
    bottom: 0; right: 0;
    width: 16px; height: 16px;
    cursor: se-resize;
    background-image:
      radial-gradient(circle, #555 1px, transparent 1px),
      radial-gradient(circle, #555 1px, transparent 1px),
      radial-gradient(circle, #555 1px, transparent 1px);
    background-size: 4px 4px;
    background-position: 8px 8px, 12px 4px, 4px 12px;
    background-repeat: no-repeat;
    opacity: 0.35;
    transition: opacity 0.15s;
    z-index: 10;
  }
  .terminal-resize-handle:hover { opacity: 0.75; }
  .terminal-window.terminal-maximized .terminal-resize-handle { display: none; }
</style>

<script define:vars={{ experience, skills }}>
  var openFn = null;

  function lazyOpen() {
    if (openFn) { openFn(); return; }

    var overlay      = document.getElementById('terminal-overlay');
    var termWindow   = document.getElementById('terminal-window');
    var header       = document.getElementById('terminal-header');
    var titleEl      = document.getElementById('terminal-title');
    var promptEl     = document.getElementById('terminal-prompt');
    var body         = document.getElementById('terminal-body');
    var output       = document.getElementById('terminal-output');
    var input        = document.getElementById('terminal-input');
    var displayArea  = document.getElementById('terminal-display-area');
    var beforeCursor = document.getElementById('term-before-cursor');
    var cursorBlock  = document.getElementById('term-cursor');
    var afterCursor  = document.getElementById('term-after-cursor');
    var btnClose     = document.getElementById('terminal-btn-close');
    var btnMinimize  = document.getElementById('terminal-btn-minimize');
    var btnMaximize  = document.getElementById('terminal-btn-maximize');
    var resizeHandle = document.getElementById('terminal-resize-handle');
    if (!overlay || !input || !output || !termWindow || !body) return;

    var previousFocus = null;
    var commandHistory = [];
    var historyIndex = -1;
    var cwd = '~';

    function updatePrompt() {
      var text = 'daniel@portfolio ' + cwd + ' %';
      if (promptEl) promptEl.textContent = text;
      if (titleEl)  titleEl.textContent  = text;
    }

    function syncCursor() {
      var val = input.value;
      var pos = input.selectionStart != null ? input.selectionStart : val.length;
      beforeCursor.textContent = val.slice(0, pos);
      cursorBlock.textContent  = val[pos] != null ? val[pos] : ' ';
      afterCursor.textContent  = val.slice(pos + 1);
    }

    input.addEventListener('input',  syncCursor);
    input.addEventListener('keyup',  syncCursor);
    input.addEventListener('click',  syncCursor);
    input.addEventListener('select', syncCursor);
    input.addEventListener('focus', function() {
      cursorBlock.style.animationPlayState = 'running';
      syncCursor();
    });
    input.addEventListener('blur', function() {
      cursorBlock.style.animationPlayState = 'paused';
    });

    displayArea.addEventListener('click', function() { input.focus(); });
    body.addEventListener('click', function(e) {
      if (!e.target.closest('button')) input.focus();
    });

    function open() {
      previousFocus = document.activeElement;
      overlay.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      if (output.children.length === 0) printMotd();
      input.focus();
      syncCursor();
    }
    openFn = open;

    function close() {
      overlay.classList.add('hidden');
      document.body.style.overflow = '';
      if (previousFocus) previousFocus.focus();
    }

    function printMotd() {
      var now    = new Date();
      var days   = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
      var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
      var pad    = function(n) { return String(n).padStart(2,'0'); };
      var ts     = days[now.getDay()] + ' ' + months[now.getMonth()] + ' ' +
                   String(now.getDate()).padStart(2,' ') + ' ' +
                   pad(now.getHours()) + ':' + pad(now.getMinutes()) + ':' + pad(now.getSeconds()) + ' ' +
                   now.getFullYear();
      appendOutput('<span class="term-muted">Last login: ' + ts + ' on ttys001</span>');
      appendOutput('');
      appendOutput('<span class="term-muted">macOS Sequoia 15.4 (portfolio edition)</span>');
      appendOutput('<span class="term-muted">──────────────────────────────────────</span>');
      appendOutput('');
      appendOutput('<span class="term-success term-bold">Welcome to Daniel\'s terminal!</span>');
      appendOutput('<span class="term-muted">Type <span class="term-accent">help</span> to see available commands.</span>');
      appendOutput('');
    }

    function appendOutput(html) {
      var line = document.createElement('div');
      line.className = 'term-line';
      line.innerHTML = html;
      output.appendChild(line);
      body.scrollTop = body.scrollHeight;
    }

    var vfs = {
      '~': {
        children: {
          'about.txt':      { type: 'file', size: ' 1.2K', cmd: 'whoami' },
          'experience.log': { type: 'file', size: ' 3.8K', cmd: 'experience' },
          'skills.json':    { type: 'file', size: ' 2.1K', cmd: 'skills' },
          'resume.pdf':     { type: 'file', size: '  84K', cmd: 'cat resume.pdf' },
          'projects':       { type: 'dir',  size: ' 160B', cmd: 'projects' },
        },
      },
      '~/projects': {
        children: {
          'vienna-districts': { type: 'dir', size: ' 4.0K', cmd: 'projects' },
          'jwt-brute':        { type: 'dir', size: ' 2.0K', cmd: 'projects' },
        },
      },
    };
    function currentDir() { return vfs[cwd] || vfs['~']; }

    var commands = {
      help: function() {
        appendOutput('<span class="term-accent term-bold">Available commands:</span>');
        appendOutput('');
        var rows = [
          ['whoami',         'About me'],
          ['skills',         'Technical skills'],
          ['experience',     'Career history'],
          ['projects',       'Open source work'],
          ['contact',        'Contact info'],
          ['ls',             'List directory'],
          ['ls -la',         'List with details'],
          ['pwd',            'Print working directory'],
          ['cd [dir]',       'Change directory'],
          ['cat [file]',     'Read a file'],
          ['date',           'Current date and time'],
          ['man [cmd]',      'Manual for a command'],
          ['cat resume.pdf', 'Download my CV'],
          ['clear',          'Clear terminal'],
        ];
        rows.forEach(function(r) {
          appendOutput('  <span class="term-success">' + r[0].padEnd(18) + '</span><span class="term-muted">' + r[1] + '</span>');
        });
        appendOutput('');
      },

      whoami: function() {
        appendOutput('<span class="term-accent term-bold">Daniel Kaufmann</span>');
        appendOutput('Software Engineer &amp; Team Captain at Dynatrace');
        appendOutput('Based in Vienna, Austria 🇦🇹');
        appendOutput('MSc Software Engineering &amp; Internet Computing @ TU Wien');
        appendOutput('');
        appendOutput('<span class="term-muted">Full-stack engineer passionate about React, TypeScript,</span>');
        appendOutput('<span class="term-muted">Deno, AI tooling, and building teams that ship quality software.</span>');
        appendOutput('');
      },

      skills: function() {
        var byCategory = {};
        skills.forEach(function(s) {
          if (!byCategory[s.category]) byCategory[s.category] = [];
          byCategory[s.category].push(s);
        });
        appendOutput('<span class="term-accent term-bold">Technical Skills</span>');
        appendOutput('');
        Object.entries(byCategory).forEach(function(kv) {
          var bar = kv[1].map(function(s) { return s.name; }).join(' · ');
          appendOutput('  <span class="term-success">' + kv[0].padEnd(14) + '</span><span class="term-muted">' + bar + '</span>');
        });
        appendOutput('');
      },

      experience: function() {
        appendOutput('<span class="term-accent term-bold">Experience</span>');
        appendOutput('<span class="term-muted">══════════════════════════════════════════════</span>');
        appendOutput('');
        experience.forEach(function(emp, ei) {
          appendOutput('  <span class="term-muted">┌─</span> <span class="term-success term-bold">' + emp.company + '</span> <span class="term-muted">· ' + emp.location + '</span>');
          appendOutput('  <span class="term-muted">│</span>');
          emp.roles.forEach(function(role, ri) {
            var isLast    = ri === emp.roles.length - 1;
            var isCurrent = role.end === 'Present';
            var connector = isLast ? '└─' : '├─';
            var pipe      = isLast ? '   ' : '│  ';
            var cls       = isCurrent ? 'term-success term-bold' : 'term-accent';
            appendOutput('  <span class="term-muted">' + connector + '</span> <span class="' + cls + '">' + role.title + '</span>');
            appendOutput('  <span class="term-muted">' + pipe + role.start + ' – ' + role.end + '</span>');
            appendOutput('  <span class="term-muted">' + pipe + '</span>' + role.description);
            appendOutput('  <span class="term-muted">' + pipe + 'Stack: ' + role.tags.join(' · ') + '</span>');
            if (!isLast) appendOutput('  <span class="term-muted">│</span>');
          });
          if (ei < experience.length - 1) appendOutput('');
        });
        appendOutput('');
      },

      projects: function() {
        appendOutput('<span class="term-accent term-bold">Projects</span>');
        appendOutput('');
        appendOutput('<span class="term-success term-bold">Vienna Districts</span>  <span class="term-muted">github.com/dkaufmann96/vienna-districts</span>');
        appendOutput('  Interactive map of Vienna\'s districts with a quiz mode.');
        appendOutput('  <span class="term-muted">Stack: Vue.js</span>');
        appendOutput('');
        appendOutput('<span class="term-success term-bold">JWT-Brute</span>  <span class="term-muted">github.com/dkaufmann96/jwt-brute</span>');
        appendOutput('  CLI tool to crack JWT signing keys via multi-core brute-force.');
        appendOutput('  <span class="term-muted">Stack: Python 3, Cryptography — educational purposes only</span>');
        appendOutput('');
      },

      contact: function() {
        appendOutput('<span class="term-accent term-bold">Contact</span>');
        appendOutput('');
        appendOutput('  <span class="term-success">Email</span>    <span class="term-muted">contact@danielkaufmann.at</span>');
        appendOutput('  <span class="term-success">GitHub</span>   <span class="term-muted">github.com/dkaufmann96</span>');
        appendOutput('  <span class="term-success">GitLab</span>   <span class="term-muted">gitlab.com/dkaufmann96</span>');
        appendOutput('');
      },

      pwd: function() {
        var path = cwd === '~'
          ? '/Users/daniel/portfolio'
          : '/Users/daniel/portfolio/' + cwd.replace('~/', '');
        appendOutput(path);
        appendOutput('');
      },

      ls: function() {
        var dir = currentDir();
        if (!dir) { appendOutput('<span class="term-error">ls: ' + cwd + ': No such directory</span>'); appendOutput(''); return; }
        appendOutput('');
        Object.entries(dir.children).forEach(function(kv) {
          if (kv[1].type === 'dir') {
            appendOutput('  <span class="term-accent term-bold">' + kv[0] + '</span>');
          } else {
            appendOutput('  ' + kv[0]);
          }
        });
        appendOutput('');
      },

      'ls -la': function() {
        var dir = currentDir();
        if (!dir) { appendOutput('<span class="term-error">ls: ' + cwd + ': No such directory</span>'); appendOutput(''); return; }
        var now = new Date();
        var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        var ds = months[now.getMonth()] + ' ' + String(now.getDate()).padStart(2,' ');
        var count = Object.keys(dir.children).length;
        appendOutput('<span class="term-muted">total ' + (count * 8) + '</span>');
        appendOutput('<span class="term-muted">drwxr-xr-x  ' + String(count + 2).padStart(2,' ') + ' daniel  staff   160B ' + ds + ' <span class="term-accent">.</span></span>');
        appendOutput('<span class="term-muted">drwxr-xr-x   5 daniel  staff   160B ' + ds + ' ..</span>');
        Object.entries(dir.children).forEach(function(kv) {
          var name = kv[0], node = kv[1];
          var perms = node.type === 'dir' ? 'drwxr-xr-x' : '-rw-r--r--';
          var nameHtml = node.type === 'dir'
            ? '<span class="term-accent term-bold">' + name + '</span>'
            : name;
          appendOutput('<span class="term-muted">' + perms + '   1 daniel  staff ' + node.size + ' ' + ds + '</span> ' + nameHtml);
        });
        appendOutput('');
      },

      date: function() {
        appendOutput(new Date().toString());
        appendOutput('');
      },

      clear: function() { output.innerHTML = ''; },

      'cat resume.pdf': function() {
        appendOutput('<span class="term-muted">Opening resume.pdf...</span>');
        appendOutput('');
        window.open('/cv.pdf', '_blank', 'noopener');
      },

      'cat resume': function() { commands['cat resume.pdf'](); },
    };

    function handleCd(arg) {
      if (!arg || arg === '~' || arg === '/') { cwd = '~'; updatePrompt(); appendOutput(''); return; }
      if (arg === '..') { cwd = '~'; updatePrompt(); appendOutput(''); return; }
      var target = arg.startsWith('~/') ? arg : (cwd === '~' ? '~/' + arg : cwd + '/' + arg);
      if (vfs[target]) { cwd = target; updatePrompt(); appendOutput(''); }
      else { appendOutput('<span class="term-error">cd: ' + arg + ': No such file or directory</span>'); appendOutput(''); }
    }

    function handleCat(arg) {
      var key = 'cat ' + arg;
      if (commands[key]) { commands[key](); return; }
      var dir = currentDir();
      if (dir && dir.children[arg]) {
        var node = dir.children[arg];
        if (node.type === 'dir') { appendOutput('<span class="term-error">cat: ' + arg + ': Is a directory</span>'); appendOutput(''); return; }
        if (commands[node.cmd]) { commands[node.cmd](); return; }
      }
      appendOutput('<span class="term-error">cat: ' + arg + ': No such file or directory</span>');
      appendOutput('');
    }

    var manPages = {
      whoami:     'Display current user info and bio.',
      skills:     'List technical skills grouped by category.',
      experience: 'Show full career history with roles and stack.',
      projects:   'List open source projects.',
      contact:    'Display contact information.',
      ls:         'List directory contents. Use -la for long format with permissions.',
      pwd:        'Print the absolute path of the current working directory.',
      cd:         'Change the current directory. cd ~ returns to root.',
      cat:        'Print file contents. Accepts files in the current directory.',
      date:       'Display the current date and time.',
      clear:      'Clear the terminal screen.',
      help:       'List all available commands.',
      man:        'Display the manual page for a command.',
    };

    function handleMan(arg) {
      var page = manPages[arg];
      if (!page) { appendOutput('<span class="term-error">No manual entry for ' + arg + '</span>'); appendOutput(''); return; }
      appendOutput('<span class="term-accent term-bold">PORTFOLIO(1)</span>             Portfolio Manual             <span class="term-accent term-bold">PORTFOLIO(1)</span>');
      appendOutput('');
      appendOutput('<span class="term-bold">NAME</span>');
      appendOutput('     <span class="term-success">' + arg + '</span>');
      appendOutput('');
      appendOutput('<span class="term-bold">DESCRIPTION</span>');
      appendOutput('     ' + page);
      appendOutput('');
    }

    var completionList = [
      'help','whoami','skills','experience','projects','contact',
      'ls','ls -la','pwd','date','clear',
      'cd ~','cd projects',
      'cat about.txt','cat experience.log','cat skills.json','cat resume.pdf',
      'man whoami','man skills','man experience','man projects','man contact',
      'man ls','man pwd','man cd','man cat','man date','man clear','man help','man man',
    ];

    function handleTab() {
      var val = input.value;
      var matches = completionList.filter(function(c) { return c.startsWith(val) && c !== val; });
      if (matches.length === 0) return;
      if (matches.length === 1) { input.value = matches[0]; syncCursor(); return; }
      var prefix = matches[0];
      matches.forEach(function(m) {
        var i = 0;
        while (i < prefix.length && i < m.length && prefix[i] === m[i]) i++;
        prefix = prefix.slice(0, i);
      });
      if (prefix.length > val.length) { input.value = prefix; syncCursor(); return; }
      appendOutput('<span class="term-cmd">' + promptEl.textContent + ' ' + val + '</span>');
      appendOutput('<span class="term-muted">' + matches.join('  ') + '</span>');
      appendOutput('');
    }

    input.addEventListener('keydown', function(e) {
      if (e.key === 'Tab') { e.preventDefault(); handleTab(); return; }

      if (e.ctrlKey) {
        if (e.key === 'l' || e.key === 'L') { e.preventDefault(); commands.clear(); return; }
        if (e.key === 'a' || e.key === 'A') { e.preventDefault(); input.setSelectionRange(0,0); syncCursor(); return; }
        if (e.key === 'e' || e.key === 'E') { e.preventDefault(); var n = input.value.length; input.setSelectionRange(n,n); syncCursor(); return; }
        if (e.key === 'u' || e.key === 'U') { e.preventDefault(); input.value = ''; syncCursor(); return; }
        if (e.key === 'w' || e.key === 'W') {
          e.preventDefault();
          var p = input.selectionStart;
          var v = input.value;
          var b = v.slice(0, p).trimEnd();
          var sp = b.lastIndexOf(' ');
          var nb = sp >= 0 ? v.slice(0, sp + 1) : '';
          input.value = nb + v.slice(p);
          input.setSelectionRange(nb.length, nb.length);
          syncCursor();
          return;
        }
      }

      if (e.key === 'Enter') {
        var raw = input.value.trim();
        var cmd = raw.toLowerCase();
        appendOutput('<span class="term-cmd">' + promptEl.textContent + ' ' + raw + '</span>');
        input.value = '';
        syncCursor();
        if (raw) { commandHistory.push(raw); historyIndex = commandHistory.length; }
        if (!raw) return;
        if (cmd.startsWith('cd '))  { handleCd(raw.slice(3).trim()); return; }
        if (cmd.startsWith('cat ')) { handleCat(raw.slice(4).trim()); return; }
        if (cmd.startsWith('man ')) { handleMan(cmd.slice(4).trim()); return; }
        var handler = commands[cmd];
        if (handler) {
          handler();
        } else {
          appendOutput('<span class="term-error">command not found: ' + raw + '</span>');
          appendOutput('<span class="term-muted">Type <span class="term-accent">help</span> for available commands.</span>');
          appendOutput('');
        }
        return;
      }

      if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (historyIndex > 0) { historyIndex--; input.value = commandHistory[historyIndex]; syncCursor(); }
        return;
      }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (historyIndex < commandHistory.length - 1) { historyIndex++; input.value = commandHistory[historyIndex]; }
        else { historyIndex = commandHistory.length; input.value = ''; }
        syncCursor();
        return;
      }
    });

    overlay.addEventListener('keydown', function(e) { if (e.key === 'Escape') close(); });
    overlay.addEventListener('click', function(e) { if (e.target === overlay) close(); });
    if (btnClose)    btnClose.addEventListener('click', close);
    if (btnMinimize) btnMinimize.addEventListener('click', function() { termWindow.classList.toggle('terminal-minimized'); });
    if (btnMaximize) btnMaximize.addEventListener('click', function() {
      termWindow.classList.toggle('terminal-maximized');
      if (!termWindow.classList.contains('terminal-maximized')) termWindow.style.position = '';
    });
    header.addEventListener('dblclick', function(e) {
      if (e.target.classList.contains('dot')) return;
      termWindow.classList.toggle('terminal-minimized');
    });

    var drag = null;
    header.addEventListener('mousedown', function(e) {
      if (e.target.classList.contains('dot')) return;
      if (termWindow.classList.contains('terminal-maximized')) return;
      e.preventDefault();
      var rect = termWindow.getBoundingClientRect();
      termWindow.style.position = 'fixed';
      termWindow.style.left     = rect.left + 'px';
      termWindow.style.top      = rect.top  + 'px';
      termWindow.style.margin   = '0';
      drag = { ox: e.clientX - rect.left, oy: e.clientY - rect.top };
      header.classList.add('is-dragging');
    });

    var resizing = null;
    if (resizeHandle) {
      resizeHandle.addEventListener('mousedown', function(e) {
        if (termWindow.classList.contains('terminal-maximized')) return;
        e.preventDefault(); e.stopPropagation();
        var rect = termWindow.getBoundingClientRect();
        resizing = { sx: e.clientX, sy: e.clientY, sw: rect.width, sh: rect.height };
      });
    }

    document.addEventListener('mousemove', function(e) {
      if (drag) {
        termWindow.style.left = (e.clientX - drag.ox) + 'px';
        termWindow.style.top  = (e.clientY - drag.oy) + 'px';
      }
      if (resizing) {
        termWindow.style.width  = Math.max(380, resizing.sw + (e.clientX - resizing.sx)) + 'px';
        termWindow.style.height = Math.max(200, resizing.sh + (e.clientY - resizing.sy)) + 'px';
      }
    });
    document.addEventListener('mouseup', function() {
      if (drag)     { drag = null; header.classList.remove('is-dragging'); }
      if (resizing) { resizing = null; }
    });

    updatePrompt();
    open();
  }

  function attachTriggers() {
    if (window.__terminalTriggersAttached) return;
    window.__terminalTriggersAttached = true;
    document.addEventListener('click', function(e) {
      if (e.target.closest('#terminal-trigger')) lazyOpen();
    });
    document.addEventListener('keydown', function(e) {
      if (e.ctrlKey && e.key === '`') { e.preventDefault(); lazyOpen(); }
    });
  }

  document.addEventListener('astro:page-load', function() {
    openFn = null;
    attachTriggers();
  });
</script>
