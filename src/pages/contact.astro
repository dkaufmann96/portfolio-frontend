---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact - Daniel Kaufmann" description="Get in touch with Daniel Kaufmann">
  <section class="max-w-lg">
    <h1 class="text-3xl font-semibold mb-2">Contact</h1>
    <p class="text-muted mb-10">I'm always happy to chat - feel free to reach out.</p>

    <div class="flex flex-col gap-4">
      <a
        href="mailto:contact@danielkaufmann.at"
        class="card hover:border-accent/40 transition-colors group flex items-center gap-4"
      >
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-muted font-medium">Email</p>
          <p class="text-text group-hover:text-accent transition-colors">contact@danielkaufmann.at</p>
        </div>
      </a>

      <a
        href="https://github.com/dkaufmann96"
        target="_blank"
        rel="noopener noreferrer"
        class="card hover:border-accent/40 transition-colors group flex items-center gap-4"
      >
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
        </div>
        <div>
          <p class="text-sm text-muted font-medium">GitHub</p>
          <p class="text-text group-hover:text-accent transition-colors">github.com/dkaufmann96</p>
        </div>
      </a>

      <a
        href="https://gitlab.com/dkaufmann96"
        target="_blank"
        rel="noopener noreferrer"
        class="card hover:border-accent/40 transition-colors group flex items-center gap-4"
      >
        <div class="w-10 h-10 rounded-full bg-accent/10 flex items-center justify-center flex-shrink-0 group-hover:bg-accent/20 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-accent" viewBox="0 0 24 24" fill="currentColor">
            <path d="M22.65 14.39L12 22.13 1.35 14.39a.84.84 0 01-.3-.94l1.22-3.78 2.44-7.51A.42.42 0 014.83 2a.43.43 0 01.58.18l2.44 7.49h8.3l2.44-7.49c.1-.28.37-.47.67-.47.3 0 .57.19.67.47l2.44 7.51 1.22 3.78c.12.35 0 .74-.28.94z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm text-muted font-medium">GitLab</p>
          <p class="text-text group-hover:text-accent transition-colors">gitlab.com/dkaufmann96</p>
        </div>
      </a>
    </div>
  </section>
</BaseLayout>
